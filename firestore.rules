rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct(data) {
      return hasRequiredFields(['id', 'name', 'uid']) &&
        data.id is string && data.name is string && data.name.size() < 100 &&
        data.uid == request.auth.uid;
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['id', 'name', 'uid']) &&
        data.id is string && data.name is string && data.name.size() < 100 &&
        data.uid == request.auth.uid;
    }

    function isValidSupplier(data) {
      return hasRequiredFields(['id', 'name', 'uid']) &&
        data.id is string && data.name is string && data.name.size() < 100 &&
        data.uid == request.auth.uid;
    }

    function isValidInvoice(data) {
      return hasRequiredFields(['id', 'number', 'date', 'total', 'type', 'uid']) &&
        data.id is string && data.number is string && data.total is number &&
        data.uid == request.auth.uid;
    }

    function isValidRecipe(data) {
      return hasRequiredFields(['id', 'name', 'uid']) &&
        data.id is string && data.name is string &&
        data.uid == request.auth.uid;
    }

    function isValidAccount(data) {
      return hasRequiredFields(['id', 'code', 'name', 'type', 'uid']) &&
        data.id is string && data.name is string &&
        data.uid == request.auth.uid;
    }

    function isValidSettings(data) {
      return hasRequiredFields(['uid']) &&
        data.uid == request.auth.uid;
    }

    function isValidExpense(data) {
      return hasRequiredFields(['id', 'date', 'description', 'amount', 'uid']) &&
        data.id is string && data.date is string && data.description is string &&
        data.amount is number && data.uid == request.auth.uid;
    }

    function isValidSocialAccount(data) {
      return hasRequiredFields(['id', 'platform', 'name', 'accessToken', 'uid']) &&
        data.id is string && data.platform is string && data.name is string &&
        data.accessToken is string && data.uid == request.auth.uid;
    }

    function isValidSocialPost(data) {
      return hasRequiredFields(['id', 'platform', 'content', 'status', 'uid']) &&
        data.id is string && data.platform is string && data.content is string &&
        data.status is string && data.uid == request.auth.uid;
    }

    function isValidSocialMessage(data) {
      return hasRequiredFields(['id', 'platform', 'senderId', 'senderName', 'text', 'timestamp', 'uid']) &&
        data.id is string && data.platform is string && data.senderId is string &&
        data.senderName is string && data.text is string && data.timestamp is string &&
        data.uid == request.auth.uid;
    }

    function isValidSocialComment(data) {
      return hasRequiredFields(['id', 'postId', 'platform', 'authorName', 'text', 'timestamp', 'uid']) &&
        data.id is string && data.postId is string && data.platform is string &&
        data.authorName is string && data.text is string && data.timestamp is string &&
        data.uid == request.auth.uid;
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /products/{productId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProduct(request.resource.data);
        allow update: if isOwner(userId) && isValidProduct(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /customers/{customerId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCustomer(request.resource.data);
        allow update: if isOwner(userId) && isValidCustomer(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /suppliers/{supplierId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSupplier(request.resource.data);
        allow update: if isOwner(userId) && isValidSupplier(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /invoices/{invoiceId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInvoice(request.resource.data);
        allow update: if isOwner(userId) && isValidInvoice(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /recipes/{recipeId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRecipe(request.resource.data);
        allow update: if isOwner(userId) && isValidRecipe(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /accounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAccount(request.resource.data);
        allow update: if isOwner(userId) && isValidAccount(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSettings(request.resource.data);
        allow update: if isOwner(userId) && isValidSettings(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /expenses/{expenseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExpense(request.resource.data);
        allow update: if isOwner(userId) && isValidExpense(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /socialAccounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSocialAccount(request.resource.data);
        allow update: if isOwner(userId) && isValidSocialAccount(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /socialPosts/{postId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSocialPost(request.resource.data);
        allow update: if isOwner(userId) && isValidSocialPost(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /socialMessages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSocialMessage(request.resource.data);
        allow update: if isOwner(userId) && isValidSocialMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /socialComments/{commentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSocialComment(request.resource.data);
        allow update: if isOwner(userId) && isValidSocialComment(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
