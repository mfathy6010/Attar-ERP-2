{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory product item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "barcode": { "type": "string" },
        "costPrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "minStock": { "type": "number" },
        "category": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "uid"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" },
        "totalPurchases": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "uid"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" },
        "totalPurchases": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "uid"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Sale or purchase invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "date": { "type": "string" },
        "customerId": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "type": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "number", "date", "total", "type", "uid"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Manufacturing recipe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "outputQuantity": { "type": "number" },
        "outputUnit": { "type": "string" },
        "ingredients": { "type": "array" },
        "totalCost": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "uid"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "balance": { "type": "number" },
        "parent": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "code", "name", "type", "uid"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" },
        "companyLogo": { "type": "string" },
        "taxId": { "type": "string" },
        "commercialRegister": { "type": "string" },
        "currency": { "type": "string" },
        "taxEnabled": { "type": "boolean" },
        "taxRate": { "type": "number" },
        "language": { "type": "string" },
        "theme": { "type": "string" },
        "primaryColor": { "type": "string" },
        "sidebarColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "fontColor": { "type": "string" },
        "fontHighlightColor": { "type": "string" },
        "inventoryMethod": { "type": "string" },
        "invoiceFooter": { "type": "string" },
        "units": { "type": "array" },
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "accountId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "date", "description", "amount", "uid"]
    },
    "SocialAccount": {
      "title": "SocialAccount",
      "description": "Connected social media account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platform": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiresAt": { "type": "number" },
        "isActive": { "type": "boolean" },
        "uid": { "type": "string" }
      },
      "required": ["id", "platform", "name", "accessToken", "uid"]
    },
    "SocialPost": {
      "title": "SocialPost",
      "description": "Social media post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platform": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrls": { "type": "array" },
        "status": { "type": "string" },
        "scheduledAt": { "type": "string" },
        "publishedAt": { "type": "string" },
        "stats": { "type": "object" },
        "uid": { "type": "string" }
      },
      "required": ["id", "platform", "content", "status", "uid"]
    },
    "SocialMessage": {
      "title": "SocialMessage",
      "description": "Social media message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platform": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "isRead": { "type": "boolean" },
        "isIncoming": { "type": "boolean" },
        "repliedTo": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "platform", "senderId", "senderName", "text", "timestamp", "uid"]
    },
    "SocialComment": {
      "title": "SocialComment",
      "description": "Social media comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "platform": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "likes": { "type": "number" },
        "replies": { "type": "array" },
        "uid": { "type": "string" }
      },
      "required": ["id", "postId", "platform", "authorName", "text", "timestamp", "uid"]
    }
  },
  "firestore": {
    "users/{uid}/products/{productId}": {
      "schema": "Product",
      "description": "User's products"
    },
    "users/{uid}/customers/{customerId}": {
      "schema": "Customer",
      "description": "User's customers"
    },
    "users/{uid}/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "User's suppliers"
    },
    "users/{uid}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User's invoices"
    },
    "users/{uid}/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "User's recipes"
    },
    "users/{uid}/accounts/{accountId}": {
      "schema": "Account",
      "description": "User's financial accounts"
    },
    "users/{uid}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User's expenses"
    },
    "users/{uid}/settings/current": {
      "schema": "Settings",
      "description": "User's settings"
    },
    "users/{uid}/socialAccounts/{accountId}": {
      "schema": "SocialAccount",
      "description": "User's connected social accounts"
    },
    "users/{uid}/socialPosts/{postId}": {
      "schema": "SocialPost",
      "description": "User's social media posts"
    },
    "users/{uid}/socialMessages/{messageId}": {
      "schema": "SocialMessage",
      "description": "User's social media messages"
    },
    "users/{uid}/socialComments/{commentId}": {
      "schema": "SocialComment",
      "description": "User's social media comments"
    }
  }
}
